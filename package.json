{
  "name": "medusa-sendcloud",
  "version": "0.0.1",
  "description": "SendCloud fulfillment module provider for Medusa v2",
  "author": "Pierre B.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierre-b/medusa-sendcloud.git"
  },
  "bugs": {
    "url": "https://github.com/pierre-b/medusa-sendcloud/issues"
  },
  "homepage": "https://github.com/pierre-b/medusa-sendcloud#readme",
  "files": [
    ".medusa/server",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin",
    "medusa-v2",
    "medusa-plugin-integration",
    "medusa-plugin-fulfillment",
    "sendcloud",
    "shipping",
    "fulfillment"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "test:unit": "TEST_TYPE=unit jest --silent --runInBand --forceExit --passWithNoTests",
    "test:integration:modules": "TEST_TYPE=integration:modules jest --silent=false --runInBand --forceExit --passWithNoTests",
    "test:integration:http": "TEST_TYPE=integration:http jest --silent=false --runInBand --forceExit --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/test-utils": "2.13.6",
    "@medusajs/ui": "4.1.6",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "nock": "^14.0.12",
    "prettier": "^3.8.2",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/test-utils": "2.13.6",
    "@medusajs/ui": "4.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.11.0"
}
